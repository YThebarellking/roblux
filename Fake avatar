-- =====================================================
-- Скрипт подмены внешности, имени и аватарок (с GUI)
-- Версия 3.0 – Toggle-галочка, полная замена частей тела
-- =====================================================

getgenv().username = getgenv().username or getgenv().Xiar_TargetUser or "Builderman"
getgenv().spoofAll = getgenv().spoofAll or getgenv().Xiar_SpoofEveryone or false

local Players = game:GetService("Players")
local LP = Players.LocalPlayer
local PlayerGui = LP:WaitForChild("PlayerGui")

local currentTarget = getgenv().username
local currentSpoofAll = getgenv().spoofAll
local spoofConnections = {}
local isSpoofing = false  -- активна ли подмена
local originalName = LP.Name
local originalDisplayName = LP.DisplayName
local originalUserId = LP.UserId
local originalHeadshot = nil  -- сохраним оригинальную аватарку

-- Получаем оригинальную аватарку при запуске
pcall(function()
    originalHeadshot = Players:GetUserThumbnailAsync(originalUserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size420x420)
end)

-- ========== Очистка подключений ==========
local function clearSpoof()
    for _, conn in ipairs(spoofConnections) do
        pcall(function() conn:Disconnect() end)
    end
    spoofConnections = {}
end

-- ========== Вспомогательные функции ==========
local function getUserId(name)
    local s, id = pcall(function()
        return Players:GetUserIdFromNameAsync(name)
    end)
    return s and id
end

local function getDisplayName(userId)
    local s, name = pcall(function()
        return Players:GetNameFromUserIdAsync(userId)
    end)
    return s and name or currentTarget
end

local function getHeadshot(userId)
    return Players:GetUserThumbnailAsync(
        userId,
        Enum.ThumbnailType.HeadShot,
        Enum.ThumbnailSize.Size420x420
    )
end

-- ========== ПОЛНАЯ ЗАМЕНА ЧАСТЕЙ ТЕЛА ==========
local function replaceCharacterParts(char, appearanceModel)
    -- Удаляем все старые части тела (кроме Humanoid и корневых объектов)
    local partsToRemove = {}
    for _, v in ipairs(char:GetChildren()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            table.insert(partsToRemove, v)
        end
    end
    for _, part in ipairs(partsToRemove) do
        part:Destroy()
    end

    -- Копируем новые части из модели внешности
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    -- Получаем все части из внешности (кроме Humanoid и HumanoidRootPart)
    local newParts = {}
    for _, v in ipairs(appearanceModel:GetChildren()) do
        if v:IsA("BasePart") and v.Name ~= "HumanoidRootPart" then
            local clone = v:Clone()
            clone.Parent = char
            table.insert(newParts, clone)
        end
    end

    -- Копируем одежду, аксессуары, BodyColors и т.д.
    for _, obj in ipairs(appearanceModel:GetChildren()) do
        if obj:IsA("Shirt") or obj:IsA("Pants") or obj:IsA("BodyColors") or obj:IsA("Accessory") then
            local clone = obj:Clone()
            if clone:IsA("Accessory") then
                clone.Parent = char
                pcall(function() humanoid:AddAccessory(clone) end)
                -- Принудительное прикрепление (если нужно)
                local handle = clone:FindFirstChild("Handle")
                if handle then
                    local accAtt = handle:FindFirstChildOfClass("Attachment")
                    if accAtt then
                        for _, targetPart in ipairs(newParts) do
                            local charAtt = targetPart:FindFirstChild(accAtt.Name)
                            if charAtt then
                                local weld = Instance.new("Weld")
                                weld.Part0 = targetPart
                                weld.Part1 = handle
                                weld.C0 = charAtt.CFrame
                                weld.C1 = accAtt.CFrame
                                weld.Parent = handle
                                break
                            end
                        end
                    end
                end
            else
                clone.Parent = char
            end
        end
    end

    -- Копируем меши и другие атрибуты (например, для "Builderman's Garden")
    -- Это делается через клонирование всех объектов, но чтобы не сломать, ограничимся частями
    -- Дополнительно можно скопировать все атрибуты из оригинальных частей
    for _, newPart in ipairs(newParts) do
        local oldPart = appearanceModel:FindFirstChild(newPart.Name)
        if oldPart then
            -- Копируем свойства (Color, Material, etc.)
            newPart.Color = oldPart.Color
            newPart.Material = oldPart.Material
            newPart.Size = oldPart.Size
            newPart.CFrame = oldPart.CFrame
            -- Копируем меши
            for _, mesh in ipairs(oldPart:GetChildren()) do
                if mesh:IsA("SpecialMesh") or mesh:IsA("BlockMesh") or mesh:IsA("CylinderMesh") then
                    local newMesh = mesh:Clone()
                    newMesh.Parent = newPart
                end
            end
        end
    end
end

-- ========== Применение внешности цели ==========
local function applyAppearance(userId)
    local success, appearance = pcall(function()
        return Players:GetCharacterAppearanceAsync(userId)
    end)
    if not success or not appearance then
        warn("Не удалось загрузить внешность")
        return false
    end
    task.wait(0.1)

    local char = LP.Character
    if not char then return false end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return false end

    -- Полная замена частей тела
    replaceCharacterParts(char, appearance)

    -- Обработка эффекта "без головы"
    local head = char:FindFirstChild("Head")
    if head then
        local isHeadless = false
        for _, v in ipairs(appearance:GetDescendants()) do
            if v:IsA("Accessory") then
                if v.Name:lower():find("headless") then
                    isHeadless = true
                    break
                end
                local handle = v:FindFirstChild("Handle")
                if handle then
                    local mesh = handle:FindFirstChildOfClass("SpecialMesh")
                    if mesh and mesh.MeshId:lower():find("134082579") then
                        isHeadless = true
                        break
                    end
                end
            end
        end
        if isHeadless then
            head.Transparency = 1
            local face = head:FindFirstChild("face")
            if face then face:Destroy() end
        else
            head.Transparency = 0
        end
    end

    return true
end

-- ========== Подмена имени ==========
local function applyName(fakeName)
    pcall(function() LP.DisplayName = fakeName end)
    local function applyToChar(char)
        pcall(function() char.Name = fakeName end)
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            pcall(function() hum.DisplayName = fakeName end)
        end
    end
    if LP.Character then applyToChar(LP.Character) end
    local conn = LP.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        applyToChar(char)
    end)
    table.insert(spoofConnections, conn)
end

-- ========== Подмена текста ==========
local function startTextSpoof(fakeName)
    local function replace(obj)
        if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then return end
        local txt = obj.Text
        local new = txt
        if currentSpoofAll then
            for _, plr in ipairs(Players:GetPlayers()) do
                new = new:gsub(plr.Name, fakeName)
            end
        else
            new = new:gsub(LP.Name, fakeName)
        end
        if new ~= txt then
            obj.Text = new
        end
    end
    local function hook(obj)
        if not (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then return end
        pcall(replace, obj)
        local conn = obj:GetPropertyChangedSignal("Text"):Connect(function()
            pcall(replace, obj)
        end)
        table.insert(spoofConnections, conn)
    end
    for _, v in ipairs(game:GetDescendants()) do
        hook(v)
    end
    table.insert(spoofConnections, game.DescendantAdded:Connect(hook))
end

-- ========== Подмена аватарок ==========
local function startHeadshotSpoof(fakeHeadshot)
    local realId = LP.UserId
    local function replace(obj)
        if not (obj:IsA("ImageLabel") or obj:IsA("ImageButton")) then return end
        if typeof(obj.Image) == "string" and obj.Image:find(tostring(realId)) then
            obj.Image = fakeHeadshot
        end
    end
    for _, v in ipairs(game:GetDescendants()) do
        replace(v)
    end
    table.insert(spoofConnections, game.DescendantAdded:Connect(replace))
end

-- ========== Запуск подмены ==========
local function startSpoof(targetName, spoofAll)
    -- Очищаем старые подключения
    clearSpoof()
    spoofConnections = {}

    local userId = getUserId(targetName)
    if not userId then
        warn("Пользователь не найден: " .. targetName)
        return false
    end

    local fakeName = getDisplayName(userId)
    local fakeHeadshot = getHeadshot(userId)

    -- Применяем внешность (полная замена частей тела)
    local success = applyAppearance(userId)
    if not success then
        warn("Не удалось применить внешность")
        return false
    end

    applyName(fakeName)
    startTextSpoof(fakeName)
    startHeadshotSpoof(fakeHeadshot)

    -- Обработка респавна
    local charAddedConn = LP.CharacterAdded:Connect(function()
        task.wait(0.1)
        if isSpoofing then
            applyAppearance(userId)
            applyName(fakeName)
        end
    end)
    table.insert(spoofConnections, charAddedConn)

    isSpoofing = true
    return true
end

-- ========== Остановка подмены (восстановление) ==========
local function stopSpoof()
    clearSpoof()
    isSpoofing = false

    -- Восстанавливаем имя
    pcall(function() LP.DisplayName = originalDisplayName end)
    if LP.Character then
        pcall(function() LP.Character.Name = originalName end)
        local hum = LP.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            pcall(function() hum.DisplayName = originalDisplayName end)
        end
    end

    -- Восстанавливаем аватарки (просто перезагружаем игру? проще перезагрузить персонажа)
    -- Перезагрузка персонажа сбросит все изменения
    LP:LoadCharacter()
end

-- ========== СОЗДАНИЕ GUI с Toggle-галочкой ==========
local function createGUI()
    local oldGui = PlayerGui:FindFirstChild("SpoofGUI")
    if oldGui then oldGui:Destroy() end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "SpoofGUI"
    screenGui.Parent = PlayerGui

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 320, 0, 180)
    frame.Position = UDim2.new(0.5, -160, 0.5, -90)
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BackgroundTransparency = 0.1
    frame.BorderSizePixel = 1
    frame.BorderColor3 = Color3.fromRGB(255, 255, 255)
    frame.Active = true
    frame.Draggable = true
    frame.Parent = screenGui

    -- Заголовок
    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, 0, 0, 30)
    title.Position = UDim2.new(0, 0, 0, 0)
    title.BackgroundTransparency = 1
    title.Text = "Подмена ника и внешности"
    title.TextColor3 = Color3.fromRGB(255, 255, 255)
    title.TextScaled = true
    title.Font = Enum.Font.GothamBold
    title.Parent = frame

    -- Контейнер для поля ввода + галочка
    local inputContainer = Instance.new("Frame")
    inputContainer.Size = UDim2.new(0.95, 0, 0, 35)
    inputContainer.Position = UDim2.new(0.025, 0, 0.3, 0)
    inputContainer.BackgroundTransparency = 1
    inputContainer.Parent = frame

    -- Поле ввода
    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(0.85, 0, 1, 0)
    textBox.Position = UDim2.new(0, 0, 0, 0)
    textBox.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    textBox.PlaceholderText = "Введите ник..."
    textBox.Text = currentTarget
    textBox.ClearTextOnFocus = false
    textBox.Font = Enum.Font.Gotham
    textBox.TextSize = 16
    textBox.Parent = inputContainer

    -- Галочка (символ ) – кликабельный Toggle
    local checkMark = Instance.new("TextButton")
    checkMark.Size = UDim2.new(0.1, 0, 1, 0)
    checkMark.Position = UDim2.new(0.88, 0, 0, 0)
    checkMark.BackgroundTransparency = 1
    checkMark.Text = ""
    checkMark.TextColor3 = Color3.fromRGB(0, 255, 0)
    checkMark.TextScaled = true
    checkMark.Font = Enum.Font.Gotham
    checkMark.Visible = isSpoofing
    checkMark.Parent = inputContainer

    -- Кнопка "Применить"
    local applyBtn = Instance.new("TextButton")
    applyBtn.Size = UDim2.new(0.85, 0, 0, 30)
    applyBtn.Position = UDim2.new(0.025, 0, 0.6, 0)
    applyBtn.BackgroundColor3 = Color3.fromRGB(0, 120, 215)
    applyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    applyBtn.Text = "Применить"
    applyBtn.Font = Enum.Font.GothamBold
    applyBtn.TextSize = 14
    applyBtn.Parent = frame

    -- Чекбокс "Подменять всех"
    local checkBox = Instance.new("TextButton")
    checkBox.Size = UDim2.new(0.85, 0, 0, 25)
    checkBox.Position = UDim2.new(0.025, 0, 0.78, 0)
    checkBox.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    checkBox.TextColor3 = Color3.fromRGB(255, 255, 255)
    checkBox.Text = "Подменять всех: ВЫКЛ"
    checkBox.Font = Enum.Font.Gotham
    checkBox.TextSize = 14
    checkBox.Parent = frame

    -- Локальное состояние чекбокса
    local spoofAllState = currentSpoofAll
    local function updateCheckBox()
        if spoofAllState then
            checkBox.Text = "Подменять всех: ВКЛ"
            checkBox.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        else
            checkBox.Text = "Подменять всех: ВЫКЛ"
            checkBox.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        end
    end
    updateCheckBox()

    -- Обработчик кнопки "Применить" (без автоматического восстановления)
    applyBtn.MouseButton1Click:Connect(function()
        local newName = textBox.Text
        if newName == "" then
            textBox.PlaceholderText = "Введите ник!"
            return
        end
        currentSpoofAll = spoofAllState
        getgenv().spoofAll = spoofAllState

        -- Если подмена уже активна, сначала отключаем
        if isSpoofing then
            stopSpoof()
        end

        local ok = startSpoof(newName, spoofAllState)
        if ok then
            checkMark.Visible = true
            currentTarget = newName
            getgenv().username = newName
            textBox.Text = newName  -- фиксируем введённый ник
        else
            checkMark.Visible = false
        end
    end)

    -- Обработчик Toggle-галочки
    checkMark.MouseButton1Click:Connect(function()
        if isSpoofing then
            stopSpoof()
            checkMark.Visible = false
            textBox.Text = currentTarget  -- возвращаем сохранённый ник в поле
        else
            -- Если не активна – применяем текущий введённый ник
            local name = textBox.Text
            if name == "" then
                textBox.PlaceholderText = "Введите ник!"
                return
            end
            currentSpoofAll = spoofAllState
            getgenv().spoofAll = spoofAllState
            local ok = startSpoof(name, spoofAllState)
            if ok then
                checkMark.Visible = true
                currentTarget = name
                getgenv().username = name
            else
                checkMark.Visible = false
            end
        end
    end)

    -- Переключение чекбокса
    checkBox.MouseButton1Click:Connect(function()
        spoofAllState = not spoofAllState
        updateCheckBox()
        -- Если подмена активна – обновляем настройку подмены текста
        if isSpoofing then
            -- перезапускаем текстовую подмену с новыми настройками
            -- для простоты можно перезапустить всю подмену
            stopSpoof()
            local name = textBox.Text
            if name ~= "" then
                local ok = startSpoof(name, spoofAllState)
                if ok then
                    checkMark.Visible = true
                    currentTarget = name
                    getgenv().username = name
                end
            end
        end
    end)

    -- При запуске применяем настройки, если цель задана
    if currentTarget and currentTarget ~= "" then
        local ok = startSpoof(currentTarget, currentSpoofAll)
        if ok then
            checkMark.Visible = true
            textBox.Text = currentTarget
        end
    end
end

-- ========== ЗАПУСК ==========
pcall(function()
    PlayerGui:FindFirstChild("SpoofGUI"):Destroy()
end)
createGUI()

--[[
    БЕССМЕРТИЕ v4.0 — исправлен автореспавн и здоровье клона
--]]

local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local workspace = game:GetService("Workspace")
local camera = workspace.CurrentCamera

-- Контейнер для клонов
local backupContainer = replicatedStorage:FindFirstChild("__BACKUPS__") or Instance.new("Folder")
if not backupContainer.Parent then
    backupContainer.Name = "__BACKUPS__"
    backupContainer.Parent = replicatedStorage
end

local clone = nil
local isRespawning = false
local isCloneActive = false      -- флаг, что мы сейчас на клоне
local healthConnection = nil
local charAddedConnection = nil  -- для перехвата респавна

-- Создание резервного клона
local function createBackup()
    if isRespawning then return end

    local character = player.Character
    if not character then return end

    -- Удаляем старый клон
    if clone then
        clone:Destroy()
        clone = nil
    end

    -- Клонируем
    if not character.Archivable then
        character.Archivable = true
    end
    local newClone = character:Clone()
    character.Archivable = false

    local cloneHumanoid = newClone:FindFirstChildOfClass("Humanoid")
    if not cloneHumanoid then
        newClone:Destroy()
        return
    end

    -- Убеждаемся, что есть HumanoidRootPart
    local rootPart = newClone:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        rootPart = Instance.new("Part")
        rootPart.Name = "HumanoidRootPart"
        rootPart.Size = Vector3.new(2, 2, 1)
        rootPart.Anchored = false
        rootPart.CanCollide = true
        rootPart.Parent = newClone
        cloneHumanoid.RootPart = rootPart
        newClone.PrimaryPart = rootPart
    else
        newClone.PrimaryPart = rootPart
    end

    -- Устанавливаем здоровье клона на максимум, чтобы он не умер сразу
    cloneHumanoid.Health = cloneHumanoid.MaxHealth
    cloneHumanoid.BreakJointsOnDeath = false  -- чтобы не разваливался
    cloneHumanoid.PlatformStand = false

    -- Прячем в контейнер
    newClone.Parent = backupContainer
    newClone.Archivable = false

    clone = newClone
end

-- Переключение на клона
local function switchToClone()
    if isRespawning or not clone then return end
    isRespawning = true

    local currentChar = player.Character
    local oldCFrame = currentChar and currentChar:GetPivot()

    -- Уничтожаем текущего персонажа
    if currentChar then
        currentChar:Destroy()
    end

    -- Подготавливаем клона
    if not clone.PrimaryPart then
        local root = clone:FindFirstChild("HumanoidRootPart")
        if root then clone.PrimaryPart = root end
    end
    if oldCFrame then
        clone:PivotTo(oldCFrame)
    end

    -- Ставим здоровье на максимум (на всякий случай)
    local hum = clone:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.Health = hum.MaxHealth
        hum.BreakJointsOnDeath = false
        hum.PlatformStand = false
    end

    -- Помещаем в мир и назначаем
    clone.Parent = workspace
    player.Character = clone
    isCloneActive = true   -- мы на клоне

    -- Принудительно обновляем камеру
    task.wait(0.05)
    if hum then
        camera.CameraSubject = hum
    else
        camera.CameraSubject = clone
    end

    -- Очищаем ссылку на клон (он теперь основной)
    clone = nil
    isRespawning = false

    -- Создаём нового клона для следующей смерти
    task.wait(0.3)
    createBackup()

    -- Включаем перехват автореспавна
    if charAddedConnection then
        charAddedConnection:Disconnect()
    end
    charAddedConnection = player.CharacterAdded:Connect(function(newChar)
        -- Если мы уже на клоне (isCloneActive = true) и появляется новый персонаж,
        -- значит сервер пытается респавнить. Удаляем нового и возвращаем нашего клона.
        if isCloneActive and newChar and newChar ~= player.Character then
            -- Но возможно, это новый персонаж создан нами (например, после респавна мы сами создали)
            -- Мы проверяем, является ли новый персонаж клоном (по наличию спец. атрибута)
            -- Просто удалим его и восстановим нашего клона, если он есть
            local ourClone = workspace:FindFirstChild("__CLONE_MAIN__") -- временный маркер
            if ourClone then
                -- Если наш клон ещё существует, делаем его основным
                if ourClone:IsA("Model") then
                    player.Character = ourClone
                    -- обновим камеру
                    local h = ourClone:FindFirstChildOfClass("Humanoid")
                    if h then
                        camera.CameraSubject = h
                        h.Health = h.MaxHealth
                    else
                        camera.CameraSubject = ourClone
                    end
                    isCloneActive = true
                end
            end
            -- Удаляем ненужного персонажа (кроме случаев, когда он наш)
            if newChar ~= player.Character and newChar.Parent == workspace then
                newChar:Destroy()
            end
        end
    end)
end

-- Обработка появления персонажа (обычного)
local function onCharacterAdded(character)
    if healthConnection then
        healthConnection:Disconnect()
        healthConnection = nil
    end

    local humanoid = character:WaitForChild("Humanoid")
    healthConnection = humanoid.Died:Connect(function()
        -- Если мы уже на клоне, то игнорируем смерть (она не должна происходить)
        if isCloneActive then
            -- но если вдруг клон умер, то попробуем переключиться на резерв
            if clone then
                switchToClone()
            else
                -- создадим нового клона и переключимся
                createBackup()
                switchToClone()
            end
            return
        end

        -- Обычная смерть — активируем клона
        if clone and not isRespawning then
            switchToClone()
        end
    end)

    -- Создаём резерв для нового персонажа (если мы не на клоне)
    if not isCloneActive then
        createBackup()
    end

    -- Помечаем нашего клона (если он есть) специальным атрибутом для распознавания
    local current = player.Character
    if current and current ~= character then
        -- это может быть наш клон, добавим маркер
        current:SetAttribute("IsCloneMain", true)
    end
end

-- Запуск для текущего персонажа
if player.Character then
    onCharacterAdded(player.Character)
else
    player.CharacterAdded:Connect(onCharacterAdded)
end

-- Периодическое обновление клона (чтобы отражать изменения)
task.spawn(function()
    while task.wait(15) do
        if not isRespawning and not isCloneActive and player.Character then
            createBackup()
        end
    end
end)

print("✅ Бессмертие v4.0 активировано (автореспавн заблокирован)")

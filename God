local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local workspace = game:GetService("Workspace")
local camera = workspace.CurrentCamera

-- Контейнер для хранения клонов (в ReplicatedStorage, чтобы не мешать)
local backupContainer = replicatedStorage:FindFirstChild("__BACKUPS__") or Instance.new("Folder")
if not backupContainer.Parent then
    backupContainer.Name = "__BACKUPS__"
    backupContainer.Parent = replicatedStorage
end

local clone = nil
local isRespawning = false
local healthConnection = nil
local updateLoop = nil

-- Создание резервной копии
local function createBackup()
    if isRespawning then return end

    local character = player.Character
    if not character then return end

    -- Удаляем старый клон
    if clone then
        clone:Destroy()
        clone = nil
    end

    -- Включаем архивирование для клонирования
    if not character.Archivable then
        character.Archivable = true
    end

    local newClone = character:Clone()
    character.Archivable = false

    -- Проверяем Humanoid
    local cloneHumanoid = newClone:FindFirstChildOfClass("Humanoid")
    if not cloneHumanoid then
        newClone:Destroy()
        return
    end

    -- Убеждаемся, что у клона есть HumanoidRootPart
    local rootPart = newClone:FindFirstChild("HumanoidRootPart")
    if not rootPart then
        -- Создаём корневую часть, если отсутствует
        rootPart = Instance.new("Part")
        rootPart.Name = "HumanoidRootPart"
        rootPart.Size = Vector3.new(2, 2, 1)
        rootPart.Anchored = false
        rootPart.CanCollide = true
        rootPart.Parent = newClone
        cloneHumanoid.RootPart = rootPart
        newClone.PrimaryPart = rootPart
    else
        newClone.PrimaryPart = rootPart
    end

    -- Прячем клон в контейнер
    newClone.Parent = backupContainer
    newClone.Archivable = false

    clone = newClone
end

-- Переключение на клона
local function switchToClone()
    if isRespawning or not clone then return end
    isRespawning = true

    local currentChar = player.Character
    local oldCFrame = nil
    if currentChar then
        oldCFrame = currentChar:GetPivot()
        currentChar:Destroy()
    end

    -- Убеждаемся, что у клона есть PrimaryPart
    if not clone.PrimaryPart then
        local root = clone:FindFirstChild("HumanoidRootPart")
        if root then
            clone.PrimaryPart = root
        else
            -- Если нет, создаём (на всякий случай)
            local hrp = Instance.new("Part")
            hrp.Name = "HumanoidRootPart"
            hrp.Size = Vector3.new(2, 2, 1)
            hrp.Anchored = false
            hrp.CanCollide = true
            hrp.Parent = clone
            local hum = clone:FindFirstChildOfClass("Humanoid")
            if hum then
                hum.RootPart = hrp
            end
            clone.PrimaryPart = hrp
        end
    end

    -- Ставим клона на место старого персонажа
    if oldCFrame then
        clone:PivotTo(oldCFrame)
    end

    -- Перемещаем в мир и назначаем игроку
    clone.Parent = workspace
    player.Character = clone

    -- ПРИНУДИТЕЛЬНО ОБНОВЛЯЕМ КАМЕРУ
    local newHumanoid = clone:FindFirstChildOfClass("Humanoid")
    if newHumanoid then
        camera.CameraSubject = newHumanoid
    else
        camera.CameraSubject = clone
    end

    -- Очищаем ссылку на клона
    clone = nil
    isRespawning = false

    -- Создаём нового клона с задержкой
    task.wait(0.3)
    createBackup()
end

-- Обработка появления персонажа
local function onCharacterAdded(character)
    -- Отключаем старый обработчик смерти
    if healthConnection then
        healthConnection:Disconnect()
        healthConnection = nil
    end

    local humanoid = character:WaitForChild("Humanoid")
    healthConnection = humanoid.Died:Connect(function()
        if not clone or not clone.Parent then
            createBackup()
            return
        end
        if not isRespawning then
            switchToClone()
        end
    end)

    createBackup()
end

-- Запуск для текущего персонажа
if player.Character then
    onCharacterAdded(player.Character)
else
    player.CharacterAdded:Connect(onCharacterAdded)
end

-- Периодическое обновление клона (каждые 15 секунд), чтобы отражать изменения экипировки
task.spawn(function()
    while task.wait(15) do
        if not isRespawning and player.Character then
            createBackup()
        end
    end
end)

print("✅ Бессмертие с фиксом камеры активировано (Delta)")

-- ================================================================
-- Режим "Призрак" v2 (исправленная версия для Delta на телефоне)
-- Переключение: кнопка на экране ИЛИ чат-команда /ghost
-- ================================================================

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local isGhost = false
local noclipConnection = nil
local clickDetectors = {}   -- кеш всех ClickDetector'ов в игре

-- ===== ПОДГОТОВКА: кешируем все ClickDetector'ы =====
local function refreshClickDetectors()
    clickDetectors = {}
    for _, obj in ipairs(workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            table.insert(clickDetectors, obj)
        end
    end
end
refreshClickDetectors()

-- Следим за новыми ClickDetector'ами
workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ClickDetector") then
        table.insert(clickDetectors, obj)
        if isGhost then
            obj.MaxActivationDistance = 0
        end
    end
end)

-- ===== ФУНКЦИИ БЛОКИРОВКИ =====

-- 1. NoClip (CanCollide) через RunService для стабильности
local function enableNoclip()
    if noclipConnection then return end
    noclipConnection = RunService.Stepped:Connect(function()
        if not character or not character.Parent then return end
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false
            end
        end
    end)
end

local function disableNoclip()
    if noclipConnection then
        noclipConnection:Disconnect()
        noclipConnection = nil
    end
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = true
            end
        end
    end
end

-- 2. Отключение ClickDetectors (через MaxActivationDistance)
local function setClickDetectorsEnabled(enabled)
    local distance = enabled and 32 or 0  -- 32 - стандартная дальность
    for _, detector in ipairs(clickDetectors) do
        detector.MaxActivationDistance = distance
    end
end

-- 3. Блокировка инструментов (Enabled)
local function setToolsEnabled(enabled)
    for _, tool in ipairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Enabled = enabled
        end
    end
    if character then
        for _, tool in ipairs(character:GetChildren()) do
            if tool:IsA("Tool") then
                tool.Enabled = enabled
            end
        end
    end
end

-- 4. Блокировка CanTouch (отключает Touched-события)
local function setCanTouch(enabled)
    if character then
        for _, part in ipairs(character:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanTouch = enabled
            end
        end
    end
end

-- ===== ПЕРЕКЛЮЧЕНИЕ РЕЖИМА =====
local function toggleGhost()
    isGhost = not isGhost

    if isGhost then
        enableNoclip()
        setClickDetectorsEnabled(false)
        setToolsEnabled(false)
        setCanTouch(false)
        button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        button.Text = "Призрак: ВКЛ"
    else
        disableNoclip()
        setClickDetectorsEnabled(true)
        setToolsEnabled(true)
        setCanTouch(true)
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        button.Text = "Призрак: ВЫКЛ"
    end
    print("Призрак:", isGhost and "ВКЛ" or "ВЫКЛ")
end

-- ===== СОЗДАНИЕ КНОПКИ (с защитой от дублирования) =====
local function createButton()
    -- Удаляем старую GUI, если есть
    if player.PlayerGui:FindFirstChild("GhostGUI") then
        player.PlayerGui.GhostGUI:Destroy()
    end

    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "GhostGUI"
    screenGui.Parent = player:WaitForChild("PlayerGui")

    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(0, 180, 0, 60)
    btn.Position = UDim2.new(0.5, -90, 0.8, -30)
    btn.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextScaled = true
    btn.Font = Enum.Font.SourceSansBold
    btn.Text = "Призрак: ВЫКЛ"
    btn.BackgroundTransparency = 0.3
    btn.Parent = screenGui

    btn.MouseButton1Click:Connect(toggleGhost)
    return btn
end

local button = createButton()

-- ===== ПОДДЕРЖКА РЕСПАВНА =====
local function onCharacterAdded(newChar)
    character = newChar
    -- Если режим был включён, применяем всё заново
    if isGhost then
        task.wait(0.5) -- даём персонажу прогрузиться
        enableNoclip()
        setClickDetectorsEnabled(false)
        setToolsEnabled(false)
        setCanTouch(false)
    else
        disableNoclip()
        setClickDetectorsEnabled(true)
        setToolsEnabled(true)
        setCanTouch(true)
    end

    -- Подключаем обработку новых инструментов для нового персонажа
    character.ChildAdded:Connect(function(tool)
        if tool:IsA("Tool") and isGhost then
            tool.Enabled = false
        end
    end)
end

player.CharacterAdded:Connect(onCharacterAdded)

-- Также подключаем обработку инструментов в рюкзаке
player.Backpack.ChildAdded:Connect(function(tool)
    if tool:IsA("Tool") and isGhost then
        tool.Enabled = false
    end
end)

-- ===== ЧАТ-КОМАНДА (поддержка старого и нового чата) =====
local function onChatMessage(message)
    if message and message.Text and message.Text:lower() == "/ghost" then
        -- Проверяем, что сообщение от нашего игрока
        if message.TextSource and message.TextSource.UserId == player.UserId then
            toggleGhost()
        end
    end
end

-- Новый чат (TextChatService)
local textChatService = game:GetService("TextChatService")
if textChatService.MessageReceived then
    textChatService.MessageReceived:Connect(onChatMessage)
else
    -- Старый чат (Players.PlayerChatted)
    player.Chatted:Connect(function(msg)
        if msg:lower() == "/ghost" then
            toggleGhost()
        end
    end)
end

-- ===== ИНИЦИАЛИЗАЦИЯ =====
-- Включаем обычный режим (всё работает)
disableNoclip()
setClickDetectorsEnabled(true)
setToolsEnabled(true)
setCanTouch(true)

print("Скрипт 'Призрак' загружен! Нажмите кнопку или напишите /ghost в чате.")

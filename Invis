-- ================================================================
-- Режим "Призрак" для Delta на телефоне
-- Переключение: нажатие на кнопку ИЛИ команда в чате /ghost
-- ================================================================

local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()

local isGhost = false

-- ===== СОЗДАНИЕ КНОПКИ НА ЭКРАНЕ =====
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GhostGUI"
screenGui.Parent = player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Size = UDim2.new(0, 180, 0, 60)
button.Position = UDim2.new(0.5, -90, 0.8, -30)  -- внизу по центру
button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextScaled = true
button.Font = Enum.Font.SourceSansBold
button.Text = "Призрак: ВЫКЛ"
button.Parent = screenGui

-- Сделаем кнопку чуть прозрачной, чтобы не мешала
button.BackgroundTransparency = 0.3

-- ===== ФУНКЦИИ БЛОКИРОВКИ =====

-- 1. CanTouch
local function setCanTouch(state)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = state
        end
    end
end

player.CharacterAdded:Connect(function(newChar)
    character = newChar
    if isGhost then setCanTouch(false) end
end)

-- 2. Инструменты
local function setToolsEnabled(state)
    for _, tool in ipairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then tool.Enabled = state end
    end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then tool.Enabled = state end
    end
end

player.Backpack.ChildAdded:Connect(function(tool)
    if tool:IsA("Tool") and isGhost then tool.Enabled = false end
end)
character.ChildAdded:Connect(function(tool)
    if tool:IsA("Tool") and isGhost then tool.Enabled = false end
end)

-- 3. ClickDetectors
local function setClickDetectorsEnabled(state)
    for _, detector in ipairs(workspace:GetDescendants()) do
        if detector:IsA("ClickDetector") then
            detector.Enabled = state
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ClickDetector") and isGhost then
        obj.Enabled = false
    end
end)

-- 4. RemoteEvent / RemoteFunction
local originals = {}
local function patchRemote(obj)
    if originals[obj] then return end
    if obj:IsA("RemoteEvent") then
        local oldFire = obj.FireServer
        originals[obj] = oldFire
        obj.FireServer = function(self, ...)
            if isGhost then return end
            return oldFire(self, ...)
        end
    elseif obj:IsA("RemoteFunction") then
        local oldInvoke = obj.InvokeServer
        originals[obj] = oldInvoke
        obj.InvokeServer = function(self, ...)
            if isGhost then return end
            return oldInvoke(self, ...)
        end
    end
end

for _, obj in ipairs(game:GetDescendants()) do
    patchRemote(obj)
end
game.DescendantAdded:Connect(patchRemote)

-- ===== ПЕРЕКЛЮЧЕНИЕ РЕЖИМА =====
local function toggleGhost()
    isGhost = not isGhost
    setCanTouch(not isGhost)
    setToolsEnabled(not isGhost)
    setClickDetectorsEnabled(not isGhost)

    if isGhost then
        button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        button.Text = "Призрак: ВКЛ"
    else
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)
        button.Text = "Призрак: ВЫКЛ"
    end
    print("Призрак:", isGhost and "ВКЛ" or "ВЫКЛ")
end

-- Нажатие на кнопку (пальцем)
button.MouseButton1Click:Connect(toggleGhost)

-- ===== КОМАНДА В ЧАТЕ =====
-- Слушаем сообщения в чате
game:GetService("TextChatService").MessageReceived:Connect(function(message)
    if message.TextSource and message.TextSource.UserId == player.UserId then
        if message.Text == "/ghost" then
            toggleGhost()
        end
    end
end)

-- Инициализация (режим выключен)
setCanTouch(true)
setToolsEnabled(true)
setClickDetectorsEnabled(true)

print("Скрипт загружен! Нажмите кнопку на экране или напишите /ghost в чате.")

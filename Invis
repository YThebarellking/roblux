-- LocalScript (вставьте в StarterGui или StarterPlayerScripts)
local player = game.Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local UserInputService = game:GetService("UserInputService")

local isGhost = false  -- состояние: true = невидим для триггеров

-- ===== СОЗДАНИЕ GUI КНОПКИ =====
local screenGui = Instance.new("ScreenGui")
screenGui.Name = "GhostModeGUI"
screenGui.Parent = player.PlayerGui  -- или player:WaitForChild("PlayerGui")

local button = Instance.new("TextButton")
button.Name = "GhostButton"
button.Size = UDim2.new(0, 150, 0, 50)
button.Position = UDim2.new(0, 10, 0, 10)  -- левый верхний угол
button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)  -- зелёный (выкл)
button.TextColor3 = Color3.fromRGB(255, 255, 255)
button.TextScaled = true
button.Font = Enum.Font.SourceSansBold
button.Text = "Призрак: ВЫКЛ"
button.Parent = screenGui

-- ===== ФУНКЦИИ БЛОКИРОВКИ =====

-- 1. Отключение CanTouch у всех частей персонажа
local function setCanTouch(state)
    for _, part in ipairs(character:GetDescendants()) do
        if part:IsA("BasePart") then
            part.CanTouch = state
        end
    end
end

player.CharacterAdded:Connect(function(newChar)
    character = newChar
    if isGhost then
        setCanTouch(false)
    end
end)

-- 2. Блокировка инструментов (Enabled = false)
local function setToolsEnabled(state)
    for _, tool in ipairs(player.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Enabled = state
        end
    end
    for _, tool in ipairs(character:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Enabled = state
        end
    end
end

local function onToolAdded(tool)
    if tool:IsA("Tool") and isGhost then
        tool.Enabled = false
    end
end
player.Backpack.ChildAdded:Connect(onToolAdded)
character.ChildAdded:Connect(onToolAdded)

-- 3. Отключение ClickDetectors
local function setClickDetectorsEnabled(state)
    for _, detector in ipairs(workspace:GetDescendants()) do
        if detector:IsA("ClickDetector") then
            detector.Enabled = state
        end
    end
end

workspace.DescendantAdded:Connect(function(obj)
    if obj:IsA("ClickDetector") and isGhost then
        obj.Enabled = false
    end
end)

-- 4. Блокировка RemoteEvent / RemoteFunction (перехват вызовов)
local originals = {}
local function patchRemote(obj)
    if originals[obj] then return end
    if obj:IsA("RemoteEvent") then
        local oldFire = obj.FireServer
        originals[obj] = { FireServer = oldFire }
        obj.FireServer = function(...)
            if isGhost then return end
            return oldFire(obj, ...)
        end
    elseif obj:IsA("RemoteFunction") then
        local oldInvoke = obj.InvokeServer
        originals[obj] = { InvokeServer = oldInvoke }
        obj.InvokeServer = function(...)
            if isGhost then return end
            return oldInvoke(obj, ...)
        end
    end
end

for _, obj in ipairs(game:GetDescendants()) do
    patchRemote(obj)
end
game.DescendantAdded:Connect(patchRemote)

-- ===== ПЕРЕКЛЮЧЕНИЕ РЕЖИМА =====
local function toggleGhost()
    isGhost = not isGhost

    -- Обновляем блокировки
    setCanTouch(not isGhost)
    setToolsEnabled(not isGhost)
    setClickDetectorsEnabled(not isGhost)
    -- Remote блокируются автоматически через isGhost

    -- Меняем внешний вид кнопки
    if isGhost then
        button.BackgroundColor3 = Color3.fromRGB(200, 0, 0)  -- красный
        button.Text = "Призрак: ВКЛ"
    else
        button.BackgroundColor3 = Color3.fromRGB(0, 170, 0)  -- зелёный
        button.Text = "Призрак: ВЫКЛ"
    end
end

-- Назначаем обработчик нажатия на кнопку (работает и на мобильных)
button.MouseButton1Click:Connect(toggleGhost)

-- Инициализация: режим выключен (всё работает)
setCanTouch(true)
setToolsEnabled(true)
setClickDetectorsEnabled(true)

-- Слайдер с обработкой (упрощённо, через InputBegan и MouseMoved)
local function setupSlider(sliderFrame, fillFrame, label, minVal, maxVal, defaultVal, callback)
    local dragging = false
    local function update(posX)
        local relative = math.clamp((posX - sliderFrame.AbsolutePosition.X) / sliderFrame.AbsoluteSize.X, 0, 1)
        local value = math.round(minVal + (maxVal - minVal) * relative)
        fillFrame.Size = UDim2.new(relative, 0, 1, 0)
        label.Text = string.format("Базовая задержка (мс): %d", value)
        delayValue = value
        if callback then callback(value) end
    end
    sliderFrame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            update(input.Position.X)
        end
    end)
    game:GetService("UserInputService").InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
        end
    end)
    game:GetService("UserInputService").InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            update(input.Position.X)
        end
    end)
    -- Установка начального значения
    local initRel = (defaultVal - minVal) / (maxVal - minVal)
    fillFrame.Size = UDim2.new(initRel, 0, 1, 0)
    label.Text = string.format("Базовая задержка (мс): %d", defaultVal)
end

setupSlider(delaySlider, delayFill, delayLabel, 50, 500, 150, function(val) delayValue = val end)


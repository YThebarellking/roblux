-- === Основная функция подделки ===
function fakePurchase(signalFunc, signalName, ids, isBulk)
    if #ids == 0 then
        sendNotification("Ошибка", "Нет ID для обработки", 3)
        return
    end

    -- Перемешиваем ID для большей случайности
    local shuffled = {}
    for i = #ids, 1, -1 do
        local j = math.random(1, i)
        shuffled[i] = ids[j]
        ids[j] = ids[i] -- простая перестановка
    end
    -- Но проще взять исходный массив и перемешать
    local shuffledIds = {}
    for i = 1, #ids do shuffledIds[i] = ids[i] end
    for i = #shuffledIds, 2, -1 do
        local j = math.random(1, i)
        shuffledIds[i], shuffledIds[j] = shuffledIds[j], shuffledIds[i]
    end

    local total = #shuffledIds
    local successCount = 0
    progressLabel.Text = "Начало обработки..."

    for idx, productID in ipairs(shuffledIds) do
        progressLabel.Text = string.format("Обработка %d/%d (ID: %d)", idx, total, productID)
        local ok = false
        local attempt = 0
        while not ok and attempt < retryCount do
            attempt = attempt + 1
            local success = false
            local errMsg = ""
            local okCall, err = pcall(function()
                -- Вызов сигнала с нужными параметрами
                if signalName == "Gamepass" then
                    MarketplaceService:SignalPromptGamePassPurchaseFinished(LocalPlayer, productID, true)
                elseif signalName == "Bulk" then
                    MarketplaceService:SignalPromptBulkPurchaseFinished(LocalPlayer.UserId, productID, true)
                elseif signalName == "Purchase" then
                    MarketplaceService:SignalPromptPurchaseFinished(LocalPlayer.UserId, productID, true)
                else -- Product
                    MarketplaceService:SignalPromptProductPurchaseFinished(LocalPlayer.UserId, productID, true)
                end
                success = true
            end)
            if okCall and success then
                ok = true
                successCount = successCount + 1
                -- Добавляем запись в лог (сигнал уже сгенерирует событие, но мы добавим дополнительно для надёжности)
                addLog(LocalPlayer.Name, productID, true, signalName)
            else
                warn(string.format("Попытка %d для ID %d не удалась: %s", attempt, productID, err or "неизвестная ошибка"))
                if attempt < retryCount then
                    local delay = (delayValue / 1000) * (1 + math.random()*0.4) -- +40% случайности
                    task.wait(delay)
                end
            end
        end
        if not ok then
            addLog(LocalPlayer.Name, productID, false, signalName)
        end
        -- Задержка между ID
        local baseDelay = delayValue / 1000
        local variance = baseDelay * 0.2
        task.wait(baseDelay + math.random(-variance, variance))
    end

    progressLabel.Text = string.format("Готово: %d из %d успешно", successCount, total)
    sendNotification("Завершено", string.format("Успешно подделано %d из %d", successCount, total), 5)
end


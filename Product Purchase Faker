function switchTab(tabName)
    local tabs = {
        Scan = {ScanTab, scannerTabFrame},
        Listener = {ListenerTab, listenerTabFrame},
        Action = {ActionTab, actionTabFrame},
        Settings = {SettingsTab, settingsTabFrame}
    }
    for name, data in pairs(tabs) do
        local btn, frame = data[1], data[2]
        if name == tabName then
            btn.BackgroundColor3 = Color3.fromRGB(104, 123, 165)
            frame.Visible = true
        else
            btn.BackgroundColor3 = Color3.fromRGB(90, 99, 109)
            frame.Visible = false
        end
    end
end


-- === Парсинг ID с поддержкой диапазонов и дубликатов ===
function parseIDs(input)
    local ids = {}
    input = input:gsub("%s+", "")
    for part in string.gmatch(input, "[^,]+") do
        local a, b = part:match("^(%d+)-(%d+)$")
        if a and b then
            a = tonumber(a)
            b = tonumber(b)
            if a and b and a <= b and (b - a) <= 1000 then
                for i = a, b do
                    table.insert(ids, i)
                end
            end
        else
            local num = tonumber(part)
            if num then
                table.insert(ids, num)
            end
        end
    end
    -- Удаление дубликатов
    local unique = {}
    for _, v in ipairs(ids) do
        if not unique[v] then
            unique[v] = true
            table.insert(unique, v) -- но это не сработает, нужно отдельный массив
        end
    end
    local result = {}
    for k, _ in pairs(unique) do
        if type(k) == "number" then
            table.insert(result, k)
        end
    end
    table.sort(result)
    return result
end


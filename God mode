-- Бессмертие через клона (Delta Roblox)
local player = game.Players.LocalPlayer
local RunService = game:GetService("RunService")

local currentChar = nil      -- текущий активный персонаж
local backupChar = nil       -- скрытый клон-дублёр
local isBackupActive = false -- флаг, чтобы не переключаться дважды

-- Создаёт скрытую копию персонажа
local function cloneCharacter(char)
    local newClone = char:Clone()
    newClone.Name = "Backup_" .. char.Name
    newClone.Parent = workspace

    -- Делаем невидимым и неактивным
    for _, part in ipairs(newClone:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 1
            part.CanCollide = false
        elseif part:IsA("Humanoid") then
            part.HealthDisplayDistance = 0
            part.PlatformStand = true
        end
    end
    return newClone
end

-- Синхронизирует инструменты (переносит новые, удаляет лишние)
local function syncTools(source, target)
    local sourceTools = {}
    for _, child in ipairs(source:GetChildren()) do
        if child:IsA("Tool") then
            sourceTools[child.Name] = child
        end
    end

    local targetTools = {}
    for _, child in ipairs(target:GetChildren()) do
        if child:IsA("Tool") then
            targetTools[child.Name] = child
        end
    end

    for name, tool in pairs(targetTools) do
        if not sourceTools[name] then
            tool:Destroy()
        end
    end

    for name, tool in pairs(sourceTools) do
        if not targetTools[name] then
            local newTool = tool:Clone()
            newTool.Parent = target
        end
    end
end

-- Основная синхронизация (здоровье, позиция, инвентарь)
local function syncBackup()
    if not currentChar or not backupChar or isBackupActive then return end

    local humanoid = currentChar:FindFirstChild("Humanoid")
    local backupHumanoid = backupChar:FindFirstChild("Humanoid")

    if humanoid and backupHumanoid then
        backupHumanoid.Health = humanoid.Health

        -- Если здоровье <= 0 – переключаемся
        if humanoid.Health <= 0 then
            switchToBackup()
        end
    end

    -- Синхронизация позиции
    local primary = currentChar:GetPrimaryPartCFrame()
    if primary then
        backupChar:SetPrimaryPartCFrame(primary)
    end

    syncTools(currentChar, backupChar)
end

-- Переключение на клона
local function switchToBackup()
    if isBackupActive or not backupChar then return end
    isBackupActive = true

    -- Ставим клона на место оригинала
    local primary = currentChar:GetPrimaryPartCFrame()
    if primary then
        backupChar:SetPrimaryPartCFrame(primary)
    end

    -- Делаем клона видимым и активным
    for _, part in ipairs(backupChar:GetDescendants()) do
        if part:IsA("BasePart") then
            part.Transparency = 0
            part.CanCollide = true
        elseif part:IsA("Humanoid") then
            part.PlatformStand = false
            part.HealthDisplayDistance = 100
        end
    end

    -- Переносим все инструменты
    syncTools(currentChar, backupChar)

    -- Удаляем мёртвого персонажа
    currentChar:Destroy()

    -- Назначаем клона как нового персонажа игрока
    player.Character = backupChar

    print("[Бессмертие] Переключено на клона!")
    -- isBackupActive сбросится в onCharacterAdded
end

-- Срабатывает при появлении нового персонажа (включая клона после переключения)
local function onCharacterAdded(newChar)
    currentChar = newChar
    isBackupActive = false

    if backupChar then backupChar:Destroy() end
    backupChar = cloneCharacter(newChar)

    -- Подписываемся на смерть, чтобы переключиться даже при быстром удалении
    local humanoid = currentChar:WaitForChild("Humanoid")
    humanoid.Died:Connect(function()
        if not isBackupActive and backupChar then
            switchToBackup()
        end
    end)
end

-- Запускаем постоянный цикл синхронизации
RunService.Heartbeat:Connect(function()
    syncBackup()
end)

-- Если персонаж уже существует – обрабатываем
if player.Character then
    onCharacterAdded(player.Character)
end

-- Следим за появлением новых персонажей (респавн, или после нашего переключения)
player.CharacterAdded:Connect(onCharacterAdded)

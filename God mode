-- Серверный скрипт (Script) в ServerScriptService
local Players = game:GetService("Players")

local function setupCloneFromCharacter(player, originalChar)
	-- Не обрабатываем, если это уже клон
	if originalChar:FindFirstChild("IsClone") then
		return
	end

	-- 1. Клонируем персонажа со всем содержимым
	local clone = originalChar:Clone()
	clone.Name = player.Name

	-- 2. Удаляем все скрипты, чтобы не было двойного выполнения
	for _, descendant in ipairs(clone:GetDescendants()) do
		if descendant:IsA("Script") or descendant:IsA("LocalScript") then
			descendant:Destroy()
		end
	end

	-- 3. Метка, чтобы не обработать клона как нового персонажа
	local isCloneTag = Instance.new("BoolValue")
	isCloneTag.Name = "IsClone"
	isCloneTag.Value = true
	isCloneTag.Parent = clone

	-- 4. Отображаемое здоровье (то, что видит игрок)
	local displayHealth = Instance.new("IntValue")
	displayHealth.Name = "DisplayHealth"
	displayHealth.Value = 100
	displayHealth.Parent = clone

	-- 5. Настраиваем Humanoid клона: бесконечный запас здоровья,
	-- чтобы Roblox не убивал персонажа при достижении 0.
	local cloneHumanoid = clone:FindFirstChild("Humanoid")
	if not cloneHumanoid then
		clone:Destroy()
		warn("[AlwaysClone] Humanoid не найден в клоне, отмена.")
		return
	end
	cloneHumanoid.MaxHealth = 1e6
	cloneHumanoid.Health = cloneHumanoid.MaxHealth

	local lastHealth = cloneHumanoid.Health
	local isResetting = false

	cloneHumanoid.HealthChanged:Connect(function(newHealth)
		if isResetting then
			lastHealth = newHealth
			return
		end

		if newHealth < lastHealth then
			local damage = lastHealth - newHealth

			-- Мгновенно восстанавливаем реальное здоровье
			isResetting = true
			cloneHumanoid.Health = cloneHumanoid.MaxHealth
			isResetting = false

			-- Уменьшаем видимое здоровье
			displayHealth.Value = math.max(0, displayHealth.Value - damage)

			-- Если видимое здоровье кончилось — восстанавливаем до 100
			-- (эффект "второго дыхания" без смены персонажа)
			if displayHealth.Value <= 0 then
				displayHealth.Value = 100
				-- Здесь можно вызвать RemoteEvent для клиента, чтобы проиграть эффект,
				-- но сейчас просто сброс.
			end
		end

		lastHealth = cloneHumanoid.Health
	end)

	-- 6. Позиционируем клона там же, где оригинал
	local originalRoot = originalChar:FindFirstChild("HumanoidRootPart")
	local cloneRoot = clone:FindFirstChild("HumanoidRootPart")
	if originalRoot and cloneRoot then
		clone:SetPrimaryPartCFrame(originalRoot.CFrame)
	end

	clone.Parent = workspace

	-- 7. Передаём клону управление и камеру, делаем его текущим персонажем
	local success = pcall(function()
		player:SetCharacter(clone)
	end)

	if not success then
		warn("[AlwaysClone] SetCharacter не удался, уничтожаем клона")
		clone:Destroy()
		return
	end

	-- 8. Удаляем оригинального персонажа (он больше не нужен)
	task.wait(0.5)
	if originalChar and originalChar.Parent then
		originalChar:Destroy()
	end
end

local function onPlayerAdded(player)
	local charConn
	charConn = player.CharacterAdded:Connect(function(character)
		setupCloneFromCharacter(player, character)
	end)

	-- Отключаем прослушку при выходе игрока
	player.AncestryChanged:Connect(function()
		charConn:Disconnect()
	end)
end

Players.PlayerAdded:Connect(onPlayerAdded)

-- Уже присутствующие игроки (на случай перезагрузки скрипта)
for _, player in ipairs(Players:GetPlayers()) do
	coroutine.wrap(onPlayerAdded)(player)
end

--[[
    Delta Executor Script: Clone with auto‑switch on death
    - Создаёт полную копию персонажа (позиция, аксессуары, эффекты и т.д.)
    - Здоровье клона всегда остаётся 100 (не может умереть)
    - При смерти оригинала управление и камера жёстко переключаются на клона
    - Оригинальный персонаж удаляется, система считает клона игроком
]]--

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

local cloneModel = nil
local originalChar = nil
local switched = false

-- Функция создания клона персонажа
local function createClone(character)
    local clone = character:Clone()
    clone.Parent = workspace
    clone.Name = player.Name .. "_Clone" -- можно убрать, чтобы имя совпадало

    local humanoid = clone:WaitForChild("Humanoid", 5)
    if not humanoid then
        warn("Humanoid не найден в клоне")
        return nil
    end

    -- Применяем описание, чтобы загрузились аксессуары (шапки, одежда и т.д.)
    humanoid:ApplyDescription(humanoid.HumanoidDescription)
    wait(0.5) -- даём время на прогрузку аксессуаров

    -- Вечный цикл: здоровье клона всегда 100
    task.spawn(function()
        while humanoid and humanoid.Parent do
            humanoid.Health = humanoid.MaxHealth
            RunService.Heartbeat:Wait()
        end
    end)

    return clone
end

-- Функция переключения управления на клона
local function switchToClone()
    if not cloneModel or not cloneModel.Parent then return end

    -- Переопределяем персонажа игрока
    pcall(function()
        player.Character = cloneModel
    end)

    -- Жёстко фиксируем камеру на клоне
    local cloneHumanoid = cloneModel:FindFirstChild("Humanoid")
    if cloneHumanoid then
        camera.CameraSubject = cloneHumanoid
        camera.CameraType = Enum.CameraType.Custom
    end

    -- Удаляем оригинального персонажа, если он ещё жив
    if originalChar and originalChar.Parent then
        originalChar:Destroy()
    end

    switched = true
    print("Переключились на клона. Оригинал удалён.")
end

-- Ожидаем появления персонажа и настраиваем всё
player.CharacterAdded:Connect(function(char)
    if switched then return end -- если уже переключились, новых персонажей игнорируем

    originalChar = char
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not humanoid then return end

    -- Создаём клона сразу, пока персонаж жив
    cloneModel = createClone(char)

    -- Мониторим здоровье: при падении до 0 (или смерти) — переключаем
    humanoid.HealthChanged:Connect(function(health)
        if health <= 0 and not switched then
            switchToClone()
        end
    end)

    humanoid.Died:Connect(function()
        if not switched then
            switchToClone()
        end
    end)
end)
